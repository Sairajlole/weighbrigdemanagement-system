rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Top-level: Companies ───────────────────────────────────────
    match /companies/{companyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;

      // ─── Company-level settings ───────────────────────────────────

      match /settings/{settingId} {
        allow read, write: if true;
      }

      // ─── Company-wide collections ──────────────────────────────────

      match /operators/{operatorId} {
        allow read, write: if true;
      }

      match /customers/{customerId} {
        allow read, write: if true;
      }

      match /customers_deleted/{customerId} {
        allow read, write: if true;
      }

      match /customer_merges/{mergeId} {
        allow read, write: if true;
      }

      match /materials/{materialId} {
        allow read, write: if true;
      }

      match /vehicles/{vehicleId} {
        allow read, write: if true;
      }

      match /auditLog/{logId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if false;
      }

      match /notifications/{notifId} {
        allow read, write: if true;
      }

      match /training_data/{sampleId} {
        allow read, write: if true;
      }

      match /rejections/{rejectionId} {
        allow read, write: if true;
      }

      match /gstin_verifications/{verificationId} {
        allow read, write: if true;
      }

      // ─── Sites ────────────────────────────────────────────────────

      match /sites/{siteId} {
        allow read, write: if true;

        match /operators/{operatorId} {
          allow read, write: if true;
        }

        match /settings/{settingId} {
          allow read, write: if true;
        }

        match /sessions/{sessionId} {
          allow read, write: if true;
        }

        // ─── Weighbridges ──────────────────────────────────────────

        match /weighbridges/{weighbridgeId} {
          allow read, write: if true;

          match /weighments/{weighmentId} {
            allow read, write: if true;
          }

          match /queues/{queueId} {
            allow read, write: if true;
          }

          match /counters/{counterId} {
            allow read, write: if true;
          }

          match /cameras/{cameraId} {
            allow read, write: if true;
          }

          match /gateEvents/{eventId} {
            allow read: if true;
            allow create: if true;
            allow update, delete: if false;
          }

          match /gateCommands/{commandId} {
            allow read, write: if true;
          }

          match /settings/{settingId} {
            allow read, write: if true;
          }

          match /materials/{materialId} {
            allow read, write: if true;
          }

          match /print_log/{logId} {
            allow read, write: if true;
          }
        }
      }
    }

    // ─── Collection group queries (for cross-company lookups) ────────

    match /{path=**}/operators/{operatorId} {
      allow read: if true;
    }

    // ─── Legacy flat collections (migration period) ─────────────────

    match /operators/{operatorId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /auditLog/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /notifications/{notifId} {
      allow read, write: if true;
    }

    match /customers/{customerId} {
      allow read, write: if true;
    }

    match /customers_deleted/{customerId} {
      allow read, write: if true;
    }

    match /customer_merges/{mergeId} {
      allow read, write: if true;
    }

    match /materials/{materialId} {
      allow read, write: if true;
    }

    match /vehicles/{vehicleId} {
      allow read, write: if true;
    }

    match /weighments/{weighmentId} {
      allow read, write: if true;
    }

    match /queues/{queueId} {
      allow read, write: if true;
    }

    match /counters/{counterId} {
      allow read, write: if true;
    }

    match /cameras/{cameraId} {
      allow read, write: if true;
    }

    match /gateEvents/{eventId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /gateCommands/{commandId} {
      allow read, write: if true;
    }

    // ─── Cloud Function collections ─────────────────────────────────

    match /licenses/{licenseId} {
      allow read: if true;
      allow write: if true;
    }

    match /verification_otps/{otpId} {
      allow read, write: if true;
    }

    match /gstin_lookups/{lookupId} {
      allow read, write: if true;
    }

    // ─── GSTIN registry (used by license system) ─────────────────────

    match /gstin_registry/{gstinId} {
      allow read, write: if true;
    }

    // ─── Global registry (used by license system) ───────────────────

    match /global/{docPath=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
